# App
APP_NAME=zup
APP_TIMEZONE=Asia/Seoul

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Database
POSTGRES_DB=zup
POSTGRES_USER=zup
POSTGRES_PASSWORD=zup
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/zup
SPRING_DATASOURCE_USERNAME=zup
SPRING_DATASOURCE_PASSWORD=zup

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# Official source collection scheduler
COLLECTION_SCHEDULER_ENABLED=false
COLLECTION_SCHEDULER_FIXED_DELAY_MS=60000
COLLECTION_SCHEDULER_BATCH_SIZE=5
COLLECTION_SCHEDULER_LOCK_TTL_SECONDS=120
COLLECTION_DEFAULT_FETCH_INTERVAL_MINUTES=1440
COLLECTION_FAILURE_RETRY_MINUTES=180

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@zup.local
ADMIN_PASSWORD=admin1234
JWT_SECRET=change-this-secret-key-for-local-development
JWT_EXPIRATION_SECONDS=86400

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
